{
  "name": "@nexusocean/firo-rpc",
  "description": "Modern TypeScript client for Firo's JSON-RPC interface",
  "version": "0.6.0",
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "NexusOcean",
    "email": "support@nexusocean.io"
  },
  "keywords": [
    "firo",
    "zcoin",
    "rpc",
    "json-rpc",
    "blockchain",
    "cryptocurrency",
    "spark",
    "lelantus"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NexusOcean/firo-rpc.git"
  },
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest --silent",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write **/*.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.46",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.4",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.6",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "bugs": {
    "url": "https://github.com/NexusOcean/firo-rpc/issues"
  },
  "homepage": "https://github.com/NexusOcean/firo-rpc"
}
